using UnityEngine;

public class LAB04_3 : MonoBehaviour
{
    public int vidaActual = 100;
    public int dañoRecibido = 20;
    
    void Start()
    {
        vidaActual = vidaActual - dañoRecibido;
        if ( vidaActual > 30)
        {
            Debug.Log("Jugador estable");
        }
        if (vidaActual > 0 && vidaActual < 31)
        {
            Debug.Log("Jugador en peligro");
        }
        if (vidaActual <= 0)
        {
            Debug.Log("Game Over");
        }
    }

    void Update()
    {
        
    }
}
